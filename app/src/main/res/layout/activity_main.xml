<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_ivory">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Bagian Gambar -->
            <View
                android:id="@+id/gambar_bunga"
                android:layout_width="0dp"
                android:layout_height="350dp"
                android:background="@color/img_placeholder"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Gambar Buket Mawar Putih)"
                android:textColor="@color/text_medium"
                app:layout_constraintTop_toTopOf="@id/gambar_bunga"
                app:layout_constraintBottom_toBottomOf="@id/gambar_bunga"
                app:layout_constraintStart_toStartOf="@id/gambar_bunga"
                app:layout_constraintEnd_toEndOf="@id/gambar_bunga" />

            <!-- Navigasi Kembali -->
            <TextView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_circle_white"
                android:elevation="4dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Favorit -->
            <TextView
                android:id="@+id/btn_fav"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="♡"
                android:textSize="28sp"
                android:gravity="center"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_circle_white"
                android:elevation="4dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Kontainer Info Produk -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/info_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_gray"
                android:backgroundTint="@color/white"
                android:padding="24dp"
                android:layout_marginTop="-30dp"
                app:layout_constraintTop_toBottomOf="@id/gambar_bunga"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/nama_produk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Mawar Putih Klasik"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Star Rating & Review -->
                <TextView
                    android:id="@+id/rating_star"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ 4.9"
                    android:textColor="@color/yellow_star"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/nama_produk"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/rating_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(128 Ulasan)"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"
                    app:layout_constraintTop_toTopOf="@id/rating_star"
                    app:layout_constraintBottom_toBottomOf="@id/rating_star"
                    app:layout_constraintStart_toEndOf="@id/rating_star" />

                <!-- Badge Terjual -->
                <TextView
                    android:id="@+id/badge_terjual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="400+ Terjual"
                    android:textColor="@color/sage_green_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@color/divider_color"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="@id/rating_star"
                    app:layout_constraintBottom_toBottomOf="@id/rating_star"
                    app:layout_constraintStart_toEndOf="@id/rating_count" />

                <!-- Deskripsi Header -->
                <TextView
                    android:id="@+id/header_deskripsi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tentang Bunga Ini"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/rating_star"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Deskripsi Tulisan -->
                <TextView
                    android:id="@+id/deskripsi_produk"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Rangkaian eksklusif 10 tangkai mawar putih segar berpadu dengan daun eucalyptus, dibalut secara elegan dengan kertas premium berkualitas. Bunga ini melambangkan kemurnian, kasih sayang, dan ketulusan, sangat cocok untuk hadiah hari jadi, kelulusan, atau kejutan spesial bagi orang tersayang."
                    android:textSize="15sp"
                    android:textColor="@color/text_medium"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/header_deskripsi"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Feature Item 1 -->
                <TextView
                    android:id="@+id/feature_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓  Gratis Kartu Ucapan"
                    android:textColor="@color/sage_green_dark"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/deskripsi_produk"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Feature Item 2 -->
                <TextView
                    android:id="@+id/feature_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓  Pengiriman Aman &amp; Cepat"
                    android:textColor="@color/sage_green_dark"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/feature_1"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Bar untuk Harga dan Action -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/label_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga Total"
            android:textSize="12sp"
            android:textColor="@color/text_light"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/harga_produk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 150.000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/sage_green_dark"
            app:layout_constraintTop_toBottomOf="@id/label_total"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Quantity Selector -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/qty_selector"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded_gray"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tombol_beli">

            <TextView
                android:id="@+id/btn_minus"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:text="−"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_dark"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/text_qty"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_dark"
                app:layout_constraintStart_toEndOf="@id/btn_minus" />

            <TextView
                android:id="@+id/btn_plus"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:text="+"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_dark"
                app:layout_constraintStart_toEndOf="@id/text_qty"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Button Keranjang -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/tombol_beli"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:text="  Beli  "
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_sage_green"
            android:paddingHorizontal="24dp"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>